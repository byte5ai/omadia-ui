node_modules/

# VitePress build artifacts
.vitepress/dist/
.vitepress/cache/

# Generated at build time from git history (single source of truth = the repo's
# git log). Regenerated by scripts/generate.mjs on every `docs:dev` / `docs:build`.
.vitepress/versions.json
.vitepress/theme/lume-tokens.css
public/previews/
history.md
latest/
# all reconstructed version snapshots (v0.1 … v0.6 …) — globbed so this list
# never drifts when a new version is added
v[0-9]*/
